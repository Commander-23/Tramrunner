LoggerPane {
    layout: grid;
    grid-size: 2;
    grid-columns: auto 1fr;
    grid-rows: 3 1fr;
    padding: 0 1 1 1;

    Label {
        width: 100%;
        height: 100%;
        content-align: center middle;
    }
    Button {
        width: 100%;
        height: 100%;
    }
    RichLog {
        column-span: 2;
    }
}
